<?xml version="1.0" encoding="utf-8"?>
<!-- MatzPhone framework defaults (RRO: MatzPhoneFrameworkOverlay) -->
<resources>
    <!-- Enhanced MAC randomization: randomize per network, re-randomize
         periodically for non-persistent networks. -->
    <bool name="config_wifi_connected_mac_randomization_supported">true</bool>

    <!-- Do not allow USB data signaling while the device is locked. -->
    <bool name="config_usbDataSignalingWhileLockedDefault">false</bool>

    <!-- No OEM/carrier usage reporting endpoints. -->
    <string name="config_deviceProvisioningPackage" translatable="false"></string>
</resources>
